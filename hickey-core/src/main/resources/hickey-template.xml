<hickey-configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                      xmlns="https://github.com/developframework/hickey/schema"
                      xsi:schemaLocation="
	https://github.com/developframework/hickey/schema hickey-configuration-0.1.xsd
    https://github.com/developframework/other-provider/schema other-provider.xsd">

    <remote-interfaces>
        <domain-prefix>http://xxx</domain-prefix>

        <remote-interface id="interface-1">

            <request method="POST">
                <url>xxx</url>
                <parameters>
                    <parameter name="name">@{parameter}</parameter>
                </parameters>
                <description>XX接口</description>
                <headers>
                    <header name="Content-Type">application/json</header>
                </headers>
                <body type="JSON">
                    <provider>
                        <kite-provider namespace="kite-student" template-id="student-detail"/>
                    </provider>
                </body>
            </request>

            <response>
                <body></body>
            </response>

        </remote-interface>
        
    </remote-interfaces>
</hickey-configuration>