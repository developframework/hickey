<hickey-configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                      xmlns="https://github.com/developframework/hickey/schema"
                      xsi:schemaLocation="
	https://github.com/developframework/hickey/schema hickey-configuration-0.1.xsd">

    <remote-interfaces group-name="groupA">

        <domain-prefix>http://localhost:8080</domain-prefix>

        <remote-interface id="interface-delete-student">

            <request method="DELETE">
                <url>/students/@{id}</url>
                <parameters>
                    <parameter name="other_param">@{otherParam}</parameter>
                </parameters>
                <description>删除学生接口</description>
                <body type="TEXT">
                    <provider>
                        <default-provider>xxxxxx@{id}</default-provider>
                    </provider>
                </body>
            </request>

        </remote-interface>
        
    </remote-interfaces>
</hickey-configuration>